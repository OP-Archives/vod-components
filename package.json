{
  "name": "@op-archives/vod-components",
  "version": "0.1.40",
  "description": "Shared VOD player components for OP-Archives streamer sites",
  "type": "module",
  "main": "./dist/index.es.js",
  "module": "./dist/index.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.es.js",
      "types": "./dist/index.d.ts",
      "style": "./dist/index.css"
    },
    "./index.css": "./dist/index.css",
    "./utils/*": {
      "import": "./dist/src/utils/*.js",
      "types": "./dist/src/utils/*.d.ts"
    },
    "./vods/*": {
      "import": "./dist/src/vods/*.js",
      "types": "./dist/src/vods/*.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "concurrently \"vite build --watch\" \"nodemon --watch dist --exec yalc push",
    "lint": "eslint \"src/**/*.{ts,tsx}\" --fix",
    "playground": "vite --config playground/vite.config.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "react",
    "vod",
    "streaming",
    "archive"
  ],
  "author": "OP-Archives",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/OP-Archives/vod-components.git"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^10.4.0",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react-compiler": "^19.1.0-rc.2",
    "globals": "^17.6.0",
    "nodemon": "^3.1.14",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.14",
    "vite-plugin-dts": "^5.0.1"
  },
  "dependencies": {
    "@twemoji/api": "^17.0.2",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "can-autoplay": "^3.0.2",
    "hls.js": "^1.6.16",
    "humanize-duration": "^3.33.2",
    "react-router-dom": "^7.15.1",
    "react-youtube": "^10.1.0",
    "simplebar-react": "^3.3.2",
    "tinyduration": "^3.4.1"
  },
  "peerDependencies": {
    "lucide-react": "^1.16.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
